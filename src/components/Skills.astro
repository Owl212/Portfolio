---
/**
 * Skills.astro
 * ─────────────────────────────────────────────────────────────────
 * Compétences techniques en grille de cartes avec icônes Lucide,
 * chips, et compteur. Soft skills en grille horizontale (optionnel).
 */
import { techSkills, softSkills } from '../data/portfolio';

const icons: Record<string, string> = {
  'code': '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
  'music': '<path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/>',
  'trending-up': '<polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/>',
  'terminal': '<polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/>',
  'brain': '<path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"/><path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"/><path d="M15 13a4.5 4.5 0 0 1-3-4 4.5 4.5 0 0 1-3 4"/><path d="M17.599 6.5a3 3 0 0 0 .399-1.375"/><path d="M6.003 5.125A3 3 0 0 0 6.401 6.5"/><path d="M3.477 10.896a4 4 0 0 1 .585-.396"/><path d="M19.938 10.5a4 4 0 0 1 .585.396"/><path d="M6 18a4 4 0 0 1-1.967-.516"/><path d="M19.967 17.484A4 4 0 0 1 18 18"/>',
  'shield-check': '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="m9 12 2 2 4-4"/>',
  'book-open': '<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>',
  'sparkles': '<path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/><path d="M5 3v4"/><path d="M19 17v4"/><path d="M3 5h4"/><path d="M17 19h4"/>',
};

function getIcon(name: string): string {
  return icons[name] || icons['code'];
}

const hasSoftSkills = softSkills.length > 0;
---

<section id="skills" class="section-wrapper">
  <div class="section-header reveal">
    <span class="section-label">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
      Compétences
    </span>
    <h2 class="section-title split-text">Mes <span class="gradient-text">Compétences</span></h2>
    <p class="section-subtitle">Technologies et savoir-faire développés à travers mes études et projets.</p>
  </div>

  <!-- Technical Skills -->
  <div class="divider-label reveal">Technical Skills</div>

  <div class="skills__grid stagger-children">
    {techSkills.map((cat) => (
      <div class="skills__card glass-card reveal" data-tilt>
        {cat.image && (
          <div class="skills__img-peek">
            <img src={cat.image} alt={cat.category} loading="lazy" decoding="async" width="300" height="200" />
          </div>
        )}
        <div class="skills__icon-box">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <Fragment set:html={getIcon(cat.icon)} />
          </svg>
        </div>
        <div class="skills__info">
          <div class="skills__title-row">
            <h3 class="skills__cat-title">{cat.category}</h3>
            <span class="skills__count">{cat.skills.length}</span>
          </div>
          <div class="skills__chips">
            {cat.skills.map((skill) => (
              <span class="skills__chip">{skill}</span>
            ))}
          </div>
        </div>
      </div>
    ))}
  </div>

  {hasSoftSkills && (
    <>
      <div class="divider-label reveal">Soft Skills</div>

      <!-- Ciao Kombucha-style shelf -->
      <div class="shelf reveal">
        <div class="shelf__row">
          {softSkills.map((skill, i) => (
            <button
              class="bottle"
              data-index={i}
              style={`--bottle-color: ${skill.color}; --bottle-delay: ${i * 80}ms`}
              aria-expanded="false"
              aria-label={`Voir la définition de ${skill.name}`}
            >
              <div class="bottle__shape">
                <div class="bottle__cap"></div>
                <div class="bottle__body">
                  <span class="bottle__emoji">{skill.emoji}</span>
                </div>
                <div class="bottle__label">
                  <span class="bottle__name">{skill.name}</span>
                </div>
                <div class="bottle__shadow"></div>
              </div>
            </button>
          ))}
        </div>

        <!-- Definition panel (shown on click) -->
        <div class="shelf__panel" id="soft-panel" aria-hidden="true">
          <button class="shelf__panel-close" aria-label="Fermer">&times;</button>
          <div class="shelf__panel-emoji" id="panel-emoji"></div>
          <h4 class="shelf__panel-title" id="panel-title"></h4>
          <p class="shelf__panel-desc" id="panel-desc"></p>
        </div>
      </div>

      <script is:inline>
        (function() {
          var softData = [];
          var bottles = document.querySelectorAll('.bottle');
          var panel = document.getElementById('soft-panel');
          var emojiEl = document.getElementById('panel-emoji');
          var titleEl = document.getElementById('panel-title');
          var descEl = document.getElementById('panel-desc');
          var activeBottle = null;

          /* Collect data from the server-rendered attributes — we pass via hidden spans */
          bottles.forEach(function(b) {
            /* We'll use a different approach: read from a global array */
          });

          /* We inject the data inline since this is static */
          softData = JSON.parse(document.getElementById('soft-skills-data').textContent);

          bottles.forEach(function(b, idx) {
            /* Wiggle on hover (Ciao Kombucha effect) */
            b.addEventListener('mouseenter', function() {
              b.classList.add('bottle--wiggle');
            });
            b.addEventListener('mouseleave', function() {
              b.classList.remove('bottle--wiggle');
            });

            /* Click to reveal definition */
            b.addEventListener('click', function() {
              var data = softData[idx];
              if (!data) return;

              if (activeBottle === idx && panel.classList.contains('shelf__panel--open')) {
                panel.classList.remove('shelf__panel--open');
                panel.setAttribute('aria-hidden', 'true');
                b.setAttribute('aria-expanded', 'false');
                activeBottle = null;
                return;
              }

              /* Deactivate previous */
              bottles.forEach(function(ob) { ob.setAttribute('aria-expanded', 'false'); ob.classList.remove('bottle--active'); });

              emojiEl.textContent = data.emoji;
              emojiEl.style.background = 'linear-gradient(135deg, ' + data.color + '33, ' + data.color + '11)';
              emojiEl.style.borderColor = data.color + '44';
              titleEl.textContent = data.name;
              titleEl.style.color = data.color;
              descEl.textContent = data.description;

              panel.classList.add('shelf__panel--open');
              panel.setAttribute('aria-hidden', 'false');
              b.setAttribute('aria-expanded', 'true');
              b.classList.add('bottle--active');
              activeBottle = idx;

              /* Smooth scroll to panel on mobile */
              if (window.innerWidth < 768) {
                panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
              }
            });
          });

          /* Close button */
          var closeBtn = panel ? panel.querySelector('.shelf__panel-close') : null;
          if (closeBtn) {
            closeBtn.addEventListener('click', function() {
              panel.classList.remove('shelf__panel--open');
              panel.setAttribute('aria-hidden', 'true');
              bottles.forEach(function(ob) { ob.setAttribute('aria-expanded', 'false'); ob.classList.remove('bottle--active'); });
              activeBottle = null;
            });
          }
        })();
      </script>

      <!-- Hidden JSON data for the script -->
      <script type="application/json" id="soft-skills-data" set:html={JSON.stringify(softSkills.map(s => ({ name: s.name, description: s.description, emoji: s.emoji, color: s.color })))} />
    </>
  )}
</section>

<style>
  .skills__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .skills__card {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    overflow: hidden;
  }

  /* ── Skill card hover image ── */
  .skills__img-peek {
    position: absolute;
    inset: 0;
    z-index: 0;
    opacity: 0;
    overflow: hidden;
    border-radius: inherit;
    transition: opacity 0.5s ease;
    pointer-events: none;
  }

  .skills__img-peek img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: blur(1px) brightness(0.3);
    transform: scale(1.1);
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .skills__card:hover .skills__img-peek {
    opacity: 1;
  }

  .skills__card:hover .skills__img-peek img {
    transform: scale(1.0);
  }

  .skills__icon-box,
  .skills__info {
    position: relative;
    z-index: 1;
  }

  .skills__icon-box {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(99, 102, 241, 0.1);
    border: 1px solid var(--border);
    border-radius: var(--border-radius-sm);
    color: var(--primary-light);
    transition: all var(--transition-base);
  }

  .skills__card:hover .skills__icon-box {
    transform: scale(1.1);
    box-shadow: 0 0 20px rgba(99, 102, 241, 0.3);
    background: rgba(99, 102, 241, 0.15);
  }

  .skills__info {
    flex: 1;
    min-width: 0;
  }

  .skills__title-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }

  .skills__cat-title {
    font-size: 1rem;
    font-weight: 600;
  }

  .skills__count {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
    background: rgba(99, 102, 241, 0.08);
    padding: 0.15rem 0.5rem;
    border-radius: 100px;
  }

  .skills__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .skills__chip {
    display: inline-block;
    padding: 0.25rem 0.65rem;
    background: rgba(99, 102, 241, 0.06);
    border: 1px solid var(--border);
    border-radius: 100px;
    font-size: 0.78rem;
    color: var(--text-secondary);
    transition: all var(--transition-fast);
    position: relative;
    contain: layout style;
  }

  .skills__chip:hover {
    color: var(--primary-light);
    border-color: var(--primary);
    text-shadow: 0 0 8px rgba(99, 102, 241, 0.6);
    animation: glitch-flicker 0.3s ease-out;
  }

  @keyframes glitch-flicker {
    0% { transform: translate(0); opacity: 1; }
    10% { transform: translate(-2px, 1px); opacity: 0.8; }
    20% { transform: translate(2px, -1px); opacity: 1; }
    30% { transform: translate(-1px, -1px); opacity: 0.9; }
    40% { transform: translate(1px, 1px); opacity: 1; }
    50% { transform: translate(0); opacity: 0.85; }
    100% { transform: translate(0); opacity: 1; }
  }

  .skills__card:hover .skills__chip {
    border-color: var(--border-hover);
  }

  /* ═══════════════════════════════════
     Soft Skills — Ciao Kombucha Shelf
     ═══════════════════════════════════ */
  .shelf {
    margin-top: 1.5rem;
  }

  .shelf__row {
    display: flex;
    justify-content: center;
    gap: clamp(1rem, 3vw, 2.5rem);
    align-items: flex-end;
    padding: 2rem 0 1rem;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .shelf__row::-webkit-scrollbar { display: none; }

  /* ── Bottle (each soft skill) ── */
  .bottle {
    all: unset;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    animation: bottle-entrance 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) backwards;
    animation-delay: var(--bottle-delay);
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),
                filter 0.3s ease;
    -webkit-tap-highlight-color: transparent;
  }

  @keyframes bottle-entrance {
    from {
      opacity: 0;
      transform: translateY(40px) scale(0.7) rotate(-8deg);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1) rotate(0deg);
    }
  }

  .bottle:hover {
    transform: translateY(-12px) scale(1.05);
    filter: brightness(1.1);
  }

  .bottle--active {
    transform: translateY(-16px) scale(1.08) !important;
  }

  .bottle--active .bottle__body {
    box-shadow: 0 0 30px var(--bottle-color), 0 8px 40px rgba(0,0,0,0.3);
  }

  .bottle--active .bottle__cap {
    background: var(--bottle-color);
  }

  /* Wiggle animation (Ciao Kombucha hover) */
  .bottle--wiggle .bottle__shape {
    animation: bottle-wiggle 0.5s ease;
  }

  @keyframes bottle-wiggle {
    0% { transform: rotate(0deg); }
    15% { transform: rotate(-6deg); }
    30% { transform: rotate(5deg); }
    45% { transform: rotate(-4deg); }
    60% { transform: rotate(3deg); }
    75% { transform: rotate(-1deg); }
    100% { transform: rotate(0deg); }
  }

  .bottle__shape {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    transform-origin: bottom center;
  }

  /* Cap (top of bottle) */
  .bottle__cap {
    width: 32px;
    height: 18px;
    background: var(--bg-glass);
    border: 2px solid var(--bottle-color);
    border-radius: 8px 8px 3px 3px;
    margin-bottom: -2px;
    z-index: 2;
    transition: background 0.3s ease;
  }

  /* Body (main shape) */
  .bottle__body {
    width: clamp(100px, 13vw, 140px);
    height: clamp(170px, 22vw, 230px);
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--bottle-color) 15%, transparent),
      color-mix(in srgb, var(--bottle-color) 30%, var(--bg-card))
    );
    border: 2px solid color-mix(in srgb, var(--bottle-color) 40%, transparent);
    border-radius: 12px 12px 20px 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    backdrop-filter: blur(8px);
    transition: box-shadow 0.4s ease, border-color 0.3s ease;
    box-shadow: 
      inset 0 -20px 30px rgba(0,0,0,0.15),
      0 4px 20px rgba(0,0,0,0.2);
  }

  /* Shine highlight on body */
  .bottle__body::before {
    content: '';
    position: absolute;
    top: 8px;
    left: 8px;
    width: 30%;
    height: 50%;
    background: linear-gradient(
      165deg,
      rgba(255,255,255,0.2) 0%,
      rgba(255,255,255,0.05) 40%,
      transparent 60%
    );
    border-radius: 8px;
    pointer-events: none;
  }

  /* Liquid fill effect */
  .bottle__body::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 65%;
    background: linear-gradient(
      0deg,
      color-mix(in srgb, var(--bottle-color) 25%, transparent),
      transparent
    );
    border-radius: 0 0 18px 18px;
    pointer-events: none;
    animation: liquid-wave 3s ease-in-out infinite;
  }

  @keyframes liquid-wave {
    0%, 100% { height: 65%; }
    50% { height: 68%; }
  }

  .bottle__emoji {
    font-size: clamp(2.2rem, 5vw, 3.2rem);
    z-index: 1;
    filter: drop-shadow(0 2px 6px rgba(0,0,0,0.3));
    transition: transform 0.3s ease;
    line-height: 1;
  }

  .bottle:hover .bottle__emoji {
    transform: scale(1.15) rotate(-5deg);
  }

  /* Label below bottle */
  .bottle__label {
    margin-top: 1rem;
    text-align: center;
    max-width: clamp(100px, 13vw, 140px);
  }

  .bottle__name {
    font-family: var(--font-mono);
    font-size: clamp(0.75rem, 1.4vw, 0.9rem);
    font-weight: 600;
    color: var(--text-secondary);
    letter-spacing: 0.02em;
    line-height: 1.3;
    transition: color 0.3s ease;
  }

  .bottle:hover .bottle__name,
  .bottle--active .bottle__name {
    color: var(--bottle-color);
  }

  /* Shadow under bottle */
  .bottle__shadow {
    width: 60%;
    height: 8px;
    background: radial-gradient(ellipse, rgba(0,0,0,0.25) 0%, transparent 70%);
    margin-top: 0.5rem;
    border-radius: 50%;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .bottle:hover .bottle__shadow {
    transform: scaleX(1.3) scaleY(0.6);
    opacity: 0.6;
  }

  /* ── Definition Panel ── */
  .shelf__panel {
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    background: var(--bg-card);
    backdrop-filter: blur(16px);
    border: 1px solid var(--border);
    border-radius: var(--border-radius);
    margin-top: 1rem;
    padding: 0 2rem;
    transition: max-height 0.5s cubic-bezier(0.4, 0, 0.2, 1),
                opacity 0.4s ease,
                padding 0.4s ease;
    position: relative;
  }

  .shelf__panel--open {
    max-height: 300px;
    opacity: 1;
    padding: 2rem;
  }

  .shelf__panel-close {
    all: unset;
    position: absolute;
    top: 1rem;
    right: 1.25rem;
    font-size: 1.5rem;
    color: var(--text-muted);
    cursor: pointer;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    transition: all 0.2s ease;
  }

  .shelf__panel-close:hover {
    background: rgba(255,255,255,0.05);
    color: var(--text-primary);
  }

  .shelf__panel-emoji {
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
    border-radius: 16px;
    border: 1px solid transparent;
    margin-bottom: 0.75rem;
  }

  .shelf__panel-title {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .shelf__panel-desc {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.7;
    max-width: 600px;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .skills__grid {
      grid-template-columns: 1fr;
    }

    .shelf__row {
      justify-content: flex-start;
      padding: 1.5rem 0.5rem 0.5rem;
      gap: 1.25rem;
    }

    .bottle__body {
      width: 85px;
      height: 145px;
    }

    .shelf__panel--open {
      padding: 1.5rem;
    }
  }
</style>
