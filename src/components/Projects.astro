---
/**
 * Projects.astro
 * ─────────────────────────────────────────────────────────────────
 * Cartes projets premium avec images thématiques, hover reveal,
 * parallax interne, numérotation gradient, style e-sport/Awwwards.
 */
import { projects } from '../data/portfolio';
---

<section id="projects" class="section-wrapper">
  <div class="section-header reveal">
    <span class="section-label">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 14 1.5-2.9A2 2 0 0 1 9.24 10H20a2 2 0 0 1 1.94 2.5l-1.54 6a2 2 0 0 1-1.95 1.5H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h3.9a2 2 0 0 1 1.69.9l.81 1.2a2 2 0 0 0 1.67.9H18a2 2 0 0 1 2 2v2"/></svg>
      Projets
    </span>
    <h2 class="section-title split-text">Case <span class="gradient-text">Studies</span></h2>
    <p class="section-subtitle">Études de cas techniques — chaque projet est un système optimisé, documenté et déployé.</p>
  </div>

  <div class="projects__grid stagger-children">
    {projects.map((project, index) => (
      <article class="project glass-card reveal" data-tilt>
        <!-- Image banner -->
        {project.image && (
          <div class="project__img-wrap">
            <img
              src={project.image}
              alt={project.title}
              class="project__img"
              loading="lazy"
              decoding="async"
              width="600"
              height="400"
            />
            <div class="project__img-overlay"></div>
            <span class="project__number gradient-text">{String(index + 1).padStart(2, '0')}</span>
          </div>
        )}

        <div class="project__body">
          <!-- Title -->
          <h3 class="project__title">
            {project.url ? (
              <a href={project.url} target="_blank" rel="noopener noreferrer" class="project__title-link magnetic-btn">
                {project.title}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
              </a>
            ) : (
              <span>{project.title}</span>
            )}
          </h3>

          <!-- Description -->
          <p class="project__desc">{project.description}</p>

          <!-- Tags -->
          <div class="project__tags">
            {project.tags.map((tag) => (
              <span class="project__tag">{tag}</span>
            ))}
          </div>

          <!-- Links -->
          <div class="project__links">
            {project.url && (
              <a href={project.url} target="_blank" rel="noopener noreferrer" class="project__link magnetic-btn">
                Voir le projet
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            )}
            {project.github && (
              <a href={project.github} target="_blank" rel="noopener noreferrer" class="project__link project__link--github magnetic-btn">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
                Code
              </a>
            )}
          </div>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .projects__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  .project {
    padding: 0;
    position: relative;
    overflow: hidden;
  }

  /* ── Image banner ── */
  .project__img-wrap {
    position: relative;
    overflow: hidden;
    height: 220px;
    border-radius: var(--border-radius) var(--border-radius) 0 0;
  }

  .project__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: transform;
  }

  .project:hover .project__img {
    transform: scale(1.08);
  }

  .project__img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 30%, rgba(10, 15, 30, 0.9) 100%);
    pointer-events: none;
    z-index: 1;
  }

  .project__number {
    font-size: 4rem;
    font-weight: 900;
    font-family: var(--font-mono);
    position: absolute;
    bottom: 0.5rem;
    right: 1rem;
    opacity: 0.25;
    line-height: 1;
    pointer-events: none;
    z-index: 2;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .project:hover .project__number {
    opacity: 0.5;
    transform: translateY(-4px);
  }

  /* ── Body ── */
  .project__body {
    padding: 1.5rem 2rem 2rem;
  }

  .project__title {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    position: relative;
  }

  .project__title-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--text-primary);
  }

  .project__title-link:hover {
    color: var(--primary-light);
  }

  .project__title-link svg {
    opacity: 0;
    transform: translateX(-4px) translateY(2px);
    transition: all var(--transition-fast);
  }

  .project__title-link:hover svg {
    opacity: 1;
    transform: translateX(0) translateY(0);
  }

  .project__desc {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

  .project__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1.25rem;
  }

  .project__tag {
    padding: 0.2rem 0.6rem;
    background: rgba(168, 85, 247, 0.08);
    border: 1px solid rgba(168, 85, 247, 0.15);
    border-radius: 100px;
    font-size: 0.75rem;
    color: var(--accent-light);
    font-weight: 500;
    transition: all var(--transition-fast);
  }

  .project:hover .project__tag {
    background: rgba(168, 85, 247, 0.15);
    border-color: rgba(168, 85, 247, 0.3);
  }

  .project__links {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .project__link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--primary-light);
    transition: all var(--transition-fast);
  }

  .project__link svg {
    transition: transform var(--transition-fast);
  }

  .project__link:hover svg {
    transform: translateX(4px);
  }

  .project__link--github {
    color: var(--text-muted);
  }

  .project__link--github:hover {
    color: var(--text-primary);
  }

  @media (max-width: 768px) {
    .projects__grid {
      grid-template-columns: 1fr;
    }

    .project__img-wrap {
      height: 180px;
    }
  }
</style>
