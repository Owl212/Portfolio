---
/**
 * Education.astro
 * ─────────────────────────────────────────────────────────────────
 * Timeline verticale avec cercles gradient, badge "Latest",
 * et cartes détaillées pour chaque formation.
 */
import { education } from '../data/portfolio';
---

<section id="education" class="section-wrapper">
  <div class="section-header reveal">
    <span class="section-label">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c0 2 6 3 6 3s6-1 6-3v-5"/></svg>
      Formation
    </span>
    <h2 class="section-title">Mon <span class="gradient-text">Parcours</span></h2>
    <p class="section-subtitle">Les étapes clés de mon parcours académique.</p>
  </div>

  <div class="edu__timeline stagger-children">
    {education.map((edu, index) => (
      <div class="edu__item reveal">
        <!-- Timeline dot -->
        <div class="edu__dot-wrapper">
          <div class="edu__dot">
            <div class="edu__dot-inner"></div>
          </div>
          {index < education.length - 1 && <div class="edu__line"></div>}
        </div>

        <!-- Content card -->
        <div class="edu__card glass-card" data-tilt>
          <div class="edu__card-header">
            <span class="edu__period">{edu.period}</span>
            {edu.isLatest && <span class="edu__badge-latest">Latest</span>}
          </div>
          <h3 class="edu__degree">{edu.degree}</h3>
          <p class="edu__field">{edu.field}</p>
          {edu.institutionUrl ? (
            <a href={edu.institutionUrl} target="_blank" rel="noopener noreferrer" class="edu__institution">
              {edu.institution}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            </a>
          ) : (
            <span class="edu__institution edu__institution--no-link">{edu.institution}</span>
          )}
          <p class="edu__description">{edu.description}</p>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .edu__timeline {
    position: relative;
    max-width: 750px;
    margin: 0 auto;
  }

  .edu__item {
    display: flex;
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .edu__item:last-child {
    margin-bottom: 0;
  }

  /* Dot & line */
  .edu__dot-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    width: 40px;
  }

  .edu__dot {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--gradient-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: 0 0 15px rgba(99, 102, 241, 0.3);
    animation: dot-glow 3s ease-in-out infinite;
    contain: layout style;
    will-change: box-shadow;
  }

  @keyframes dot-glow {
    0%, 100% { box-shadow: 0 0 10px rgba(99, 102, 241, 0.2); }
    50% { box-shadow: 0 0 25px rgba(99, 102, 241, 0.5); }
  }

  .edu__dot-inner {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--bg-primary);
  }

  .edu__line {
    width: 2px;
    flex: 1;
    background: var(--border);
    margin-top: 8px;
    position: relative;
    overflow: hidden;
  }

  .edu__line::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 20px;
    background: linear-gradient(180deg, var(--primary), transparent);
    animation: circuit-trace 2.5s ease-in-out infinite;
    will-change: transform;
  }

  @keyframes circuit-trace {
    0% { transform: translateY(-100%); opacity: 0; }
    20% { opacity: 1; }
    80% { opacity: 1; }
    100% { transform: translateY(calc(500%)); opacity: 0; }
  }

  /* Card */
  .edu__card {
    flex: 1;
  }

  .edu__card-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .edu__period {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
    background: rgba(99, 102, 241, 0.08);
    padding: 0.2rem 0.75rem;
    border-radius: 100px;
    border: 1px solid var(--border);
  }

  .edu__badge-latest {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--success);
    background: rgba(34, 197, 94, 0.1);
    padding: 0.15rem 0.6rem;
    border-radius: 100px;
    border: 1px solid rgba(34, 197, 94, 0.2);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .edu__degree {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 0.35rem;
  }

  .edu__field {
    font-size: 0.9rem;
    color: var(--accent-light);
    margin-bottom: 0.5rem;
  }

  .edu__institution {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.85rem;
    color: var(--primary-light);
    margin-bottom: 0.75rem;
  }

  .edu__institution--no-link {
    color: var(--text-secondary);
  }

  .edu__description {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .edu__dot-wrapper {
      display: none;
    }

    .edu__item {
      gap: 0;
    }
  }
</style>
