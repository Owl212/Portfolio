---
/**
 * BaseLayout.astro
 * ─────────────────────────────────────────────────────────────────
 * Layout principal du portfolio. Gère le HTML wrapper, les styles
 * globaux, les polices, les animations de fond (orbes), le script
 * de scroll-reveal, le Header et le Footer.
 * Le slot reçoit le contenu assemblé par la page index.
 */
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BackToTop from '../components/BackToTop.astro';
import { personalInfo } from '../data/portfolio';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Abdelaziz Khoungui',
  description = personalInfo.subtitle,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="author" content={`${personalInfo.firstName} ${personalInfo.lastName}`} />
  <meta name="theme-color" content="#0a0f1e" />
  <meta name="color-scheme" content="dark" />
  <meta name="robots" content="index, follow" />
  <meta name="generator" content="Astro" />
  <title>{title}</title>

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content="https://portfolio-uhqy.vercel.app" />
  <meta property="og:site_name" content="Abdelaziz Khoungui" />
  <meta property="og:locale" content="fr_FR" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  <!-- Preconnect (critical fonts) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <!-- Preload critical font files -->
  <link rel="preload" href="https://fonts.gstatic.com/s/inter/v18/UcCO3FwrK3iLTeHuS_nVMrMxCp50SjIw2boKoduKmMEVuLyfAZ9hiA.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="https://fonts.gstatic.com/s/jetbrainsmono/v20/tDbY2o-flEEny0FZhsfKu5WU4zr3E_BX0PnT8RD8yKxjPVmUsaaDhw.woff2" as="font" type="font/woff2" crossorigin />

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="canonical" href="https://portfolio-uhqy.vercel.app" />

  <!-- Schema.org JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ProfilePage",
    "mainEntity": {
      "@type": "Person",
      "name": personalInfo.name,
      "jobTitle": personalInfo.title,
      "description": personalInfo.subtitle,
      "email": personalInfo.email,
      "telephone": personalInfo.phone,
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Fès",
        "addressCountry": "MA"
      },
      "url": "https://portfolio-uhqy.vercel.app",
      "sameAs": [
        "https://github.com/Owl212",
        "https://www.linkedin.com/in/abdelaziz-khoungui-428355397"
      ],
      "alumniOf": {
        "@type": "EducationalOrganization",
        "name": "ESISA",
        "url": "https://www.esisa.ac.ma"
      },
      "knowsAbout": [
        "Low-Level Programming",
        "C Language",
        "CPU Architecture",
        "Digital Signal Processing",
        "Audio Engineering",
        "Financial Analysis",
        "Web Development"
      ]
    }
  })} />
</head>
<body>
  <!-- Preloader -->
  <div class="preloader" id="preloader" aria-hidden="true">
    <div class="preloader__inner">
      <div class="preloader__logo">
        <span class="preloader__bracket">&lt;</span><span class="preloader__name gradient-text">AK</span><span class="preloader__bracket"> /&gt;</span>
      </div>
      <div class="preloader__bar">
        <div class="preloader__fill" id="preloader-fill"></div>
      </div>
      <span class="preloader__text" id="preloader-text">Initialisation...</span>
    </div>
  </div>

  <!-- Scroll Progress Bar -->
  <div class="scroll-progress" id="scroll-progress" aria-hidden="true"></div>

  <!-- Skip link -->
  <a href="#main-content" class="skip-link">Aller au contenu principal</a>

  <!-- Background decorative elements -->
  <div class="bg-grid" aria-hidden="true"></div>
  <div class="noise-overlay" aria-hidden="true"></div>
  <div class="orb orb--1" aria-hidden="true"></div>
  <div class="orb orb--2" aria-hidden="true"></div>
  <div class="orb orb--3" aria-hidden="true"></div>
  <canvas class="mesh-gradient" id="mesh-gradient" aria-hidden="true"></canvas>

  <Header />

  <main id="main-content">
    <slot />
  </main>

  <Footer />
  <BackToTop />

  <!-- Preloader + Scroll Progress + Scroll Reveal Engine -->
  <script is:inline>
    /* === PRELOADER === */
    (function() {
      var fill = document.getElementById('preloader-fill');
      var text = document.getElementById('preloader-text');
      var preloader = document.getElementById('preloader');
      var steps = ['Chargement des modules...', 'Compilation des shaders...', 'Rendu du DOM...', 'Prêt.'];
      var progress = 0;

      function tick() {
        progress += Math.random() * 18 + 5;
        if (progress > 100) progress = 100;
        fill.style.width = progress + '%';
        var stepIdx = Math.min(Math.floor(progress / 25), steps.length - 1);
        text.textContent = steps[stepIdx];
        if (progress < 100) {
          setTimeout(tick, 150 + Math.random() * 200);
        } else {
          setTimeout(function() {
            preloader.classList.add('preloader--done');
            document.body.classList.remove('loading');
            setTimeout(function() { preloader.style.display = 'none'; }, 700);
          }, 300);
        }
      }

      document.body.classList.add('loading');
      tick();
    })();

    /* === SCROLL PROGRESS BAR === */
    (function() {
      var bar = document.getElementById('scroll-progress');
      var ticking = false;
      window.addEventListener('scroll', function() {
        if (!ticking) {
          ticking = true;
          requestAnimationFrame(function() {
            var scrollTop = window.scrollY;
            var docHeight = document.documentElement.scrollHeight - window.innerHeight;
            var progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
            bar.style.width = progress + '%';
            ticking = false;
          });
        }
      }, { passive: true });
    })();

    /* === SCROLL REVEAL (multi-directional) === */
    (function() {
      var observer = new IntersectionObserver(
        function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('revealed');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
      );

      function observe() {
        document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-scale').forEach(function(el) {
          observer.observe(el);
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', observe);
      } else {
        observe();
      }
    })();
  </script>

  <!-- 3D Mouse Tracking Parallax Tilt Engine -->
  <script is:inline>
    (function() {
      /* ── Accessibility gates ── */
      var mql = window.matchMedia('(prefers-reduced-motion: reduce)');
      if (mql.matches) return;
      var isTouch = 'ontouchstart' in window || navigator.maxTouchPoints > 0;
      if (isTouch) return;

      /* ── Config ── */
      var MAX_ROT   = 15;    /* degrees */
      var PERSP     = 1000;  /* px */
      var SPRING    = 'transform 0.6s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.6s ease';
      var GLARE_TR  = 'opacity 0.3s ease';

      function initTilt() {
        var cards = document.querySelectorAll('[data-tilt]');
        cards.forEach(function(card) {
          /* Avoid double-init */
          if (card._tiltInit) return;
          card._tiltInit = true;

          /* Create glare layer */
          var glare = document.createElement('div');
          glare.className = 'tilt-glare';
          card.appendChild(glare);

          var raf = null;

          card.addEventListener('mouseenter', function() {
            /* Kill CSS transition on enter for instant response */
            card.style.transition = 'none';
            glare.style.transition = 'none';
          });

          card.addEventListener('mousemove', function(e) {
            if (raf) cancelAnimationFrame(raf);
            raf = requestAnimationFrame(function() {
              var rect = card.getBoundingClientRect();
              /* Normalised coords: center = 0, edges = ±1 */
              var nx = ((e.clientX - rect.left) / rect.width  - 0.5) * 2;
              var ny = ((e.clientY - rect.top)  / rect.height - 0.5) * 2;

              /* Invert so card tilts TOWARD the cursor */
              var rx = -ny * MAX_ROT;
              var ry =  nx * MAX_ROT;

              card.style.transform =
                'perspective(' + PERSP + 'px) rotateX(' + rx + 'deg) rotateY(' + ry + 'deg) translateZ(0)';
              card.style.boxShadow =
                (ry * -0.5) + 'px ' + (rx * 0.5) + 'px 30px rgba(99,102,241,' + (0.15 + Math.abs(nx * ny) * 0.2) + ')';

              /* Move glare to cursor position */
              var gx = ((e.clientX - rect.left) / rect.width)  * 100;
              var gy = ((e.clientY - rect.top)  / rect.height) * 100;
              glare.style.background =
                'radial-gradient(circle at ' + gx + '% ' + gy + '%, rgba(255,255,255,0.12) 0%, rgba(255,255,255,0.05) 35%, transparent 65%)';
              glare.style.opacity = '1';
            });
          });

          card.addEventListener('mouseleave', function() {
            if (raf) cancelAnimationFrame(raf);
            /* Spring-back transition */
            card.style.transition = SPRING;
            card.style.transform  = 'perspective(' + PERSP + 'px) rotateX(0deg) rotateY(0deg) translateZ(0)';
            card.style.boxShadow  = '';
            glare.style.transition = GLARE_TR;
            glare.style.opacity    = '0';
          });
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initTilt);
      } else {
        initTilt();
      }
    })();
  </script>

  <!-- Dynamism Engine v2 — Preeminent Portfolio Interactions -->
  <script is:inline>
    (function() {
      var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      var isTouch = 'ontouchstart' in window || navigator.maxTouchPoints > 0;

      /* ═══════════════════════════════════════════════════════════
         2. MAGNETIC BUTTONS
         ═══════════════════════════════════════════════════════════ */
      if (!isTouch && !reduced) {
        document.querySelectorAll('.magnetic-btn').forEach(function(btn) {
          btn.addEventListener('mousemove', function(e) {
            var rect = btn.getBoundingClientRect();
            var mx = e.clientX - rect.left - rect.width / 2;
            var my = e.clientY - rect.top - rect.height / 2;
            btn.style.transform = 'translate(' + (mx * 0.25) + 'px,' + (my * 0.25) + 'px)';
          });
          btn.addEventListener('mouseleave', function() {
            btn.style.transition = 'transform 0.5s cubic-bezier(0.34,1.56,0.64,1)';
            btn.style.transform = 'translate(0,0)';
            setTimeout(function() { btn.style.transition = ''; }, 500);
          });
        });
      }

      /* ═══════════════════════════════════════════════════════════
         3. SPLIT-TEXT CHARACTER REVEAL
         ═══════════════════════════════════════════════════════════ */
      function initSplitText() {
        document.querySelectorAll('.split-text').forEach(function(el) {
          if (el.dataset.split) return;
          el.dataset.split = '1';
          var html = el.innerHTML;
          var inTag = false;
          var result = '';
          var charIndex = 0;
          for (var i = 0; i < html.length; i++) {
            if (html[i] === '<') { inTag = true; result += html[i]; continue; }
            if (html[i] === '>') { inTag = false; result += html[i]; continue; }
            if (inTag) { result += html[i]; continue; }
            if (html[i] === ' ') {
              result += ' ';
            } else {
              result += '<span class="split-char" style="animation-delay:' + (charIndex * 30) + 'ms">' + html[i] + '</span>';
              charIndex++;
            }
          }
          el.innerHTML = result;
        });
      }

      /* ═══════════════════════════════════════════════════════════
         4. COUNTER ANIMATION
         ═══════════════════════════════════════════════════════════ */
      function animateCounters() {
        var counters = document.querySelectorAll('.hero__stat-value');
        var counterObs = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (!entry.isIntersecting) return;
            var el = entry.target;
            counterObs.unobserve(el);
            var text = el.textContent || '';
            var match = text.match(/(\d+)/);
            if (!match) return;
            var target = parseInt(match[1]);
            var suffix = text.replace(match[1], '');
            var duration = 1500;
            var start = performance.now();
            function tick(now) {
              var p = Math.min((now - start) / duration, 1);
              var ease = 1 - Math.pow(1 - p, 3);
              var current = Math.round(target * ease);
              el.textContent = current + suffix;
              if (p < 1) requestAnimationFrame(tick);
            }
            el.textContent = '0' + suffix;
            requestAnimationFrame(tick);
          });
        }, { threshold: 0.5 });
        counters.forEach(function(c) { counterObs.observe(c); });
      }

      /* ═══════════════════════════════════════════════════════════
         5. PARALLAX SCROLL + SCROLL VELOCITY
         ═══════════════════════════════════════════════════════════ */
      if (!reduced) {
        var parallaxEls = [];
        function initParallax() {
          parallaxEls = [];
          document.querySelectorAll('[data-parallax]').forEach(function(el) {
            parallaxEls.push({
              el: el,
              speed: parseFloat(el.dataset.parallax) || 0.1
            });
          });
          document.querySelectorAll('.orb').forEach(function(el) {
            parallaxEls.push({ el: el, speed: 0.04 });
          });
        }

        /* Scroll velocity tracker for marquees */
        var lastScrollY = 0;
        var scrollVelocity = 0;
        var velTicking = false;

        window.addEventListener('scroll', function() {
          if (!velTicking) {
            velTicking = true;
            requestAnimationFrame(function() {
              var scrollY = window.scrollY;
              scrollVelocity = Math.abs(scrollY - lastScrollY);
              lastScrollY = scrollY;

              /* Apply parallax */
              parallaxEls.forEach(function(p) {
                p.el.style.transform = 'translateY(' + (scrollY * p.speed) + 'px)';
              });

              /* Dynamically speed up marquees based on scroll velocity */
              var speedMultiplier = 1 + Math.min(scrollVelocity / 30, 3);
              document.querySelectorAll('.marquee__track').forEach(function(track) {
                var baseDuration = parseFloat(track.style.animationDuration) || 30;
                track.style.animationDuration = (baseDuration / speedMultiplier) + 's';
              });

              /* Skew marquees with velocity (Awwwards effect) */
              var skew = Math.min(scrollVelocity * 0.15, 5);
              document.querySelectorAll('.marquee').forEach(function(m) {
                m.style.transform = 'skewY(' + skew + 'deg)';
              });

              velTicking = false;
            });
          }
        }, { passive: true });

        /* Reset marquee speed/skew when scroll stops */
        var scrollTimer;
        window.addEventListener('scroll', function() {
          clearTimeout(scrollTimer);
          scrollTimer = setTimeout(function() {
            document.querySelectorAll('.marquee__track').forEach(function(track) {
              var d = track.closest('[data-speed]');
              var base = d ? d.dataset.speed : '30';
              track.style.animationDuration = base + 's';
            });
            document.querySelectorAll('.marquee').forEach(function(m) {
              m.style.transform = 'skewY(0deg)';
            });
          }, 150);
        }, { passive: true });

        /* ═══════════════════════════════════════════════════════
           6. SECTION SCALE-IN
           ═══════════════════════════════════════════════════════ */
        var scaleObs = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('section-visible');
            }
          });
        }, { threshold: 0.05, rootMargin: '0px 0px -10% 0px' });

        document.querySelectorAll('.section-wrapper').forEach(function(s) {
          s.classList.add('section-scale');
          scaleObs.observe(s);
        });

        initParallax();
      }

      /* ═══════════════════════════════════════════════════════════
         7. SMOOTH HOVER LINE
         ═══════════════════════════════════════════════════════════ */
      document.querySelectorAll('.header__link').forEach(function(link) {
        var line = document.createElement('span');
        line.className = 'hover-line';
        link.appendChild(line);
      });

      /* ═══════════════════════════════════════════════════════════
         8. MESH GRADIENT CANVAS (interactive background)
         ═══════════════════════════════════════════════════════════ */
      if (!reduced && !isTouch) {
        var canvas = document.getElementById('mesh-gradient');
        if (canvas) {
          var ctx = canvas.getContext('2d');
          var w, h;
          var mouseX = 0.5, mouseY = 0.5;
          var points = [
            { x: 0.1, y: 0.2, vx: 0.0003, vy: 0.0004, r: 200, color: 'rgba(99,102,241,0.08)' },
            { x: 0.8, y: 0.3, vx: -0.0002, vy: 0.0003, r: 250, color: 'rgba(168,85,247,0.06)' },
            { x: 0.5, y: 0.8, vx: 0.0004, vy: -0.0002, r: 220, color: 'rgba(236,72,153,0.05)' },
          ];

          function resize() {
            w = canvas.width = window.innerWidth;
            h = canvas.height = window.innerHeight;
          }
          resize();
          window.addEventListener('resize', resize);

          document.addEventListener('mousemove', function(e) {
            mouseX = e.clientX / w;
            mouseY = e.clientY / h;
          });

          function drawMesh() {
            ctx.clearRect(0, 0, w, h);
            points.forEach(function(p) {
              p.x += p.vx + (mouseX - 0.5) * 0.0002;
              p.y += p.vy + (mouseY - 0.5) * 0.0002;
              if (p.x < 0 || p.x > 1) p.vx *= -1;
              if (p.y < 0 || p.y > 1) p.vy *= -1;
              p.x = Math.max(0, Math.min(1, p.x));
              p.y = Math.max(0, Math.min(1, p.y));

              var grad = ctx.createRadialGradient(p.x * w, p.y * h, 0, p.x * w, p.y * h, p.r);
              grad.addColorStop(0, p.color);
              grad.addColorStop(1, 'transparent');
              ctx.fillStyle = grad;
              ctx.fillRect(0, 0, w, h);
            });
            requestAnimationFrame(drawMesh);
          }
          drawMesh();
        }
      }

      /* ═══════════════════════════════════════════════════════════
         9. TEXT SCRAMBLE EFFECT on hero title
         ═══════════════════════════════════════════════════════════ */
      function initTextScramble() {
        var el = document.querySelector('.hero__title-scramble');
        if (!el) return;
        var finalText = el.textContent || '';
        var chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789@#$%&*';
        var iterations = 0;
        var interval = setInterval(function() {
          el.textContent = finalText.split('').map(function(char, i) {
            if (i < iterations) return finalText[i];
            return chars[Math.floor(Math.random() * chars.length)];
          }).join('');
          iterations += 1 / 2;
          if (iterations >= finalText.length) {
            el.textContent = finalText;
            clearInterval(interval);
          }
        }, 30);
      }

      /* ═══════════════════════════════════════════════════════════
         10. INIT ALL
         ═══════════════════════════════════════════════════════════ */
      function initAll() {
        if (!reduced) initSplitText();
        animateCounters();
        initTextScramble();
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initAll);
      } else {
        initAll();
      }
    })();
  </script>

  <!-- Vercel Analytics & Speed Insights -->
  <script>
    import { inject } from '@vercel/analytics';
    import { injectSpeedInsights } from '@vercel/speed-insights';
    inject();
    injectSpeedInsights();
  </script>
</body>
</html>

<style is:global>
  /* ═══════════════════════════════════════════════════════════════
     CSS Custom Properties — Design System
     ═══════════════════════════════════════════════════════════════ */
  :root {
    /* Colors */
    --bg-primary: #0a0f1e;
    --bg-secondary: #0f1629;
    --bg-card: rgba(15, 22, 41, 0.6);
    --bg-glass: rgba(15, 22, 41, 0.75);
    --text-primary: #f0f2f5;
    --text-secondary: #94a3b8;
    --text-muted: #64748b;
    --primary: #6366f1;
    --primary-light: #818cf8;
    --accent: #a855f7;
    --accent-light: #c084fc;
    --success: #22c55e;
    --warning: #f59e0b;
    --border: rgba(99, 102, 241, 0.15);
    --border-hover: rgba(99, 102, 241, 0.35);
    --glow: rgba(99, 102, 241, 0.2);
    --glow-strong: rgba(99, 102, 241, 0.4);

    /* Gradients */
    --gradient-primary: linear-gradient(135deg, #6366f1, #a855f7, #ec4899);
    --gradient-text: linear-gradient(135deg, #6366f1, #a855f7, #ec4899, #6366f1);
    --gradient-subtle: linear-gradient(135deg, rgba(99, 102, 241, 0.1), rgba(168, 85, 247, 0.1));
    --gradient-card-hover: linear-gradient(90deg, #6366f1, #a855f7, #ec4899);

    /* Fonts */
    --font-sans: 'Inter', system-ui, -apple-system, sans-serif;
    --font-mono: 'JetBrains Mono', ui-monospace, monospace;

    /* Dimensions */
    --header-height: 72px;
    --header-height-scrolled: 56px;
    --max-width: 1200px;
    --section-padding: 6rem 2rem;
    --border-radius: 16px;
    --border-radius-sm: 10px;
    --border-radius-xs: 6px;

    /* Shadows */
    --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.3);
    --shadow-md: 0 4px 16px rgba(0, 0, 0, 0.4);
    --shadow-lg: 0 8px 32px rgba(0, 0, 0, 0.5);
    --shadow-glow: 0 0 30px rgba(99, 102, 241, 0.15);

    /* Transitions */
    --transition-fast: 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    --transition-base: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    --transition-spring: 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  /* ═══════════════════════════════════════════════════════════════
     Global Reset & Base Styles
     ═══════════════════════════════════════════════════════════════ */
  *, *::before, *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
    scroll-padding-top: var(--header-height);
  }

  body {
    font-family: var(--font-sans);
    background-color: var(--bg-primary);
    color: var(--text-primary);
    line-height: 1.7;
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* Text selection */
  ::selection {
    background: rgba(99, 102, 241, 0.3);
    color: var(--text-primary);
  }

  /* Focus visible */
  :focus-visible {
